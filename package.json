{
  "name": "pawhaven-vet-clinic",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "PawHaven — a premium, deploy-ready veterinary clinic website template built with React, Vite, Tailwind CSS v4 and Framer Motion.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
